                      setOpticBatteryReplaced(event.target.value)
                    }
                    className="mt-2 w-full rounded-xl border border-slate-800 bg-slate-950 px-3 py-2 text-[13px] text-slate-200 outline-none transition focus:border-blue-500/60"
                  >
                    <option>N/A</option>
                    <option>Checked</option>
                    <option>Replaced</option>
                    <option>Needs Replacement</option>
                  </select>
                </label>

                <label className="block">
                  <FieldLabel>Cleaning Condition</FieldLabel>
                  <select
                    value={cleaningCondition}
                    onChange={(event) =>
                      setCleaningCondition(event.target.value)
                    }
                    className="mt-2 w-full rounded-xl border border-slate-800 bg-slate-950 px-3 py-2 text-[13px] text-slate-200 outline-none transition focus:border-blue-500/60"
                  >
                    <option>Acceptable</option>
                    <option>Needs Cleaning</option>
                    <option>Needs Lubrication</option>
                    <option>Unsatisfactory</option>
                  </select>
                </label>
              </div>
            </section>

            <section className="rounded-3xl border border-slate-800 bg-slate-900">
              <div className="border-b border-slate-800 px-5 py-4">
                <h2 className="text-[15px] font-bold text-white">
                  Inspection Checklist
                </h2>
                <p className="mt-1 text-[12px] text-slate-500">
                  Critical items prevent a Passed result if marked Fail.
                </p>
              </div>

              <div className="space-y-5 p-5">
                {Object.entries(checklistSections).map(([section, items]) => (
                  <div key={section} className="space-y-3">
                    <h3 className="text-[12px] font-bold uppercase tracking-widest text-slate-500">
                      {section}
                    </h3>

                    {items.map((item) => (
                      <div
                        key={item.id}
                        className="rounded-2xl border border-slate-800 bg-slate-950/60 p-4"
                      >
                        <div className="flex flex-col gap-3">
                          <div className="flex flex-col gap-2 md:flex-row md:items-start md:justify-between">
                            <div>
                              <p className="text-[13px] font-semibold text-slate-100">
                                {item.label}
                              </p>
                              {item.critical ? (
                                <p className="mt-1 text-[11px] text-amber-300">
                                  Critical item
                                </p>
                              ) : null}
                            </div>

                            <div className="flex flex-wrap gap-2">
                              {(["Pass", "Fail", "N/A"] as ChecklistStatus[]).map(
                                (status) => (
                                  <button
                                    key={status}
                                    type="button"
                                    onClick={() =>
                                      updateChecklistStatus(item.id, status)
                                    }
                                    className={`rounded-xl border px-3 py-1.5 text-[11px] font-semibold transition ${
                                      item.status === status
                                        ? status === "Fail"
                                          ? "border-red-500 bg-red-500/10 text-red-200"
                                          : status === "Pass"
                                            ? "border-emerald-500 bg-emerald-500/10 text-emerald-200"
                                            : "border-slate-600 bg-slate-700/30 text-slate-200"
                                        : "border-slate-700 text-slate-400 hover:border-blue-500/50 hover:text-white"
                                    }`}
                                  >
                                    {status}
                                  </button>
                                ),
                              )}
                            </div>
                          </div>

                          <input
                            value={item.note}
                            onChange={(event) =>
                              updateChecklistNote(item.id, event.target.value)
                            }
                            placeholder="Optional item note"
                            className="w-full rounded-xl border border-slate-800 bg-slate-950 px-3 py-2 text-[12px] text-slate-200 outline-none transition placeholder:text-slate-600 focus:border-blue-500/60"
                          />
                        </div>
                      </div>
                    ))}
                  </div>
                ))}
              </div>
            </section>
          </div>

          <aside className="space-y-5">
            <section className="rounded-3xl border border-slate-800 bg-slate-900">
              <div className="border-b border-slate-800 px-5 py-4">
                <div className="flex items-center gap-2">
                  <Wrench size={17} className="text-amber-300" />
                  <h2 className="text-[15px] font-bold text-white">
                    Result & Disposition
                  </h2>
                </div>
              </div>

              <div className="space-y-4 p-5">
                <label className="block">
                  <FieldLabel>Overall Result</FieldLabel>
                  <select
                    value={result}
                    onChange={(event) =>
                      setResult(event.target.value as (typeof RESULTS)[number])
                    }
                    className="mt-2 w-full rounded-xl border border-slate-800 bg-slate-950 px-3 py-2 text-[13px] text-slate-200 outline-none transition focus:border-blue-500/60"
                  >
                    {RESULTS.map((item) => (
                      <option key={item} value={item}>
                        {item}
                      </option>
                    ))}
                  </select>
                </label>

                <label className="block">
                  <FieldLabel>Service Recommendation</FieldLabel>
                  <select
                    value={serviceRecommendation}
                    onChange={(event) =>
                      setServiceRecommendation(
                        event.target
                          .value as (typeof SERVICE_RECOMMENDATIONS)[number],
                      )
                    }
                    className="mt-2 w-full rounded-xl border border-slate-800 bg-slate-950 px-3 py-2 text-[13px] text-slate-200 outline-none transition focus:border-blue-500/60"
                  >
                    {SERVICE_RECOMMENDATIONS.map((item) => (
                      <option key={item} value={item}>
                        {item}
                      </option>
                    ))}
                  </select>
                </label>

                <label className="block">
                  <FieldLabel>Follow-Up Date</FieldLabel>
                  <input
                    type="date"
                    value={followUpDate}
                    onChange={(event) => setFollowUpDate(event.target.value)}
                    className="mt-2 w-full rounded-xl border border-slate-800 bg-slate-950 px-3 py-2 text-[13px] text-slate-200 outline-none transition focus:border-blue-500/60"
                  />
                </label>

                <label className="block">
                  <FieldLabel>Corrective Action / Maintenance Needed</FieldLabel>
                  <textarea
                    value={correctiveAction}
                    onChange={(event) =>
                      setCorrectiveAction(event.target.value)
                    }
                    rows={4}
                    placeholder="Document required maintenance, parts, armorer review, or removal from service reason."
                    className="mt-2 w-full rounded-xl border border-slate-800 bg-slate-950 px-3 py-2 text-[13px] text-slate-200 outline-none transition placeholder:text-slate-600 focus:border-blue-500/60"
                  />
                </label>

                <label className="block">
                  <FieldLabel>Inspection Notes</FieldLabel>
                  <textarea
                    value={notes}
                    onChange={(event) => setNotes(event.target.value)}
                    rows={5}
                    placeholder="General notes, condition details, officer comments, range observations, or return-to-service notes."
                    className="mt-2 w-full rounded-xl border border-slate-800 bg-slate-950 px-3 py-2 text-[13px] text-slate-200 outline-none transition placeholder:text-slate-600 focus:border-blue-500/60"
                  />
                </label>
              </div>
            </section>

            <section className="rounded-3xl border border-slate-800 bg-slate-900">
              <div className="border-b border-slate-800 px-5 py-4">
                <h2 className="text-[15px] font-bold text-white">
                  Inspection Summary
                </h2>
              </div>

              <div className="space-y-3 p-5 text-[12px] text-slate-400">
                <div className="flex items-center justify-between rounded-2xl border border-slate-800 bg-slate-950/60 p-3">
                  <span>Failed checklist items</span>
                  <span className="font-bold text-white">
                    {failedItems.length}
                  </span>
                </div>

                <div className="flex items-center justify-between rounded-2xl border border-slate-800 bg-slate-950/60 p-3">
                  <span>Critical failures</span>
                  <span
                    className={`font-bold ${
                      failedCriticalItems.length > 0
                        ? "text-red-300"
                        : "text-emerald-300"
                    }`}
                  >
                    {failedCriticalItems.length}
                  </span>
                </div>

                <div className="rounded-2xl border border-slate-800 bg-slate-950/60 p-3">
                  <p className="font-semibold text-slate-300">
                    Selected firearm
                  </p>
                  <p className="mt-1 text-slate-500">
                    {selectedFirearm
                      ? `${getFirearmName(selectedFirearm)} · ${
                          selectedFirearm.serial_number || "No serial"
                        }`
                      : "None selected"}
                  </p>
                </div>

                <button
                  type="button"
                  onClick={handleSaveInspection}
                  className="inline-flex w-full items-center justify-center gap-2 rounded-xl bg-blue-600 px-4 py-2.5 text-[12px] font-semibold text-white transition hover:bg-blue-500"
                >
                  <Save size={14} />
                  Save Inspection
                </button>

                <p className="text-[11px] leading-5 text-slate-600">
                  Save currently validates the completed form. Next step is
                  connecting this to the inspection database/API and applying
                  firearm status changes.
                </p>
              </div>
            </section>
          </aside>
        </section>
      </div>
    </TracePointShell>
  );
}

export default function NewInspectionPage() {
  return (
    <Suspense fallback={null}>
      <NewInspectionContent />
    </Suspense>
  );
}