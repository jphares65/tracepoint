    (typeof SERVICE_RECOMMENDATIONS)[number]
  >("Remain In Service");
  const [followUpDate, setFollowUpDate] = useState("");
  const [correctiveAction, setCorrectiveAction] = useState("");
  const [notes, setNotes] = useState("");

  const loadArmory = useCallback(async () => {
    setLoading(true);
    setLoadError(null);

    try {
      const response = await fetch("/api/armory/firearms", {
        cache: "no-store",
      });

      const payload = (await response.json()) as
        | ArmoryResponse
        | { error?: string };

      if (!response.ok) {
        throw new Error(
          "error" in payload && payload.error
            ? payload.error
            : "The Armory records could not be loaded.",
        );
      }

      setFirearms((payload as ArmoryResponse).firearms);
    } catch (error) {
      setLoadError(
        error instanceof Error
          ? error.message
          : "The Armory records could not be loaded.",
      );
    } finally {
      setLoading(false);
    }
  }, []);

  useEffect(() => {
    void loadArmory();
  }, [loadArmory]);

  const selectedFirearm = useMemo(
    () => firearms.find((firearm) => firearm.id === selectedFirearmId) ?? null,
    [firearms, selectedFirearmId],
  );

  const checklistSections = useMemo(() => {
    return checklist.reduce<Record<string, ChecklistItem[]>>((groups, item) => {
      if (!groups[item.section]) groups[item.section] = [];
      groups[item.section].push(item);
      return groups;
    }, {});
  }, [checklist]);

  const failedItems = checklist.filter((item) => item.status === "Fail");
  const failedCriticalItems = failedItems.filter((item) => item.critical);

  function updateChecklistStatus(id: string, status: ChecklistStatus) {
    setChecklist((current) =>
      current.map((item) => (item.id === id ? { ...item, status } : item)),
    );
  }

  function updateChecklistNote(id: string, note: string) {
    setChecklist((current) =>
      current.map((item) => (item.id === id ? { ...item, note } : item)),
    );
  }

  async function handleSaveInspection() {
    setSubmitError(null);
    setSavedMessage(null);

    if (!selectedFirearm) {
      setSubmitError("Select a firearm before saving the inspection.");
      return;
    }

    if (!inspectorName.trim()) {
      setSubmitError("Enter the inspector name before saving.");
      return;
    }

    if (result === "Passed" && failedCriticalItems.length > 0) {
      setSubmitError(
        "This inspection cannot be marked Passed while critical checklist items are failed.",
      );
      return;
    }

    try {
      const inspectionDateTime = new Date(
        `${inspectionDate}T${inspectionTime || "00:00"}`,
      ).toISOString();

      const response = await fetch("/api/armory/inspections", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify({
          firearmId: selectedFirearm.id,
          inspectionType,
          inspectionReason,
          inspectionDate: inspectionDateTime,
          inspectorName,
          inspectionLocation,
          assigneeName:
            selectedFirearm.active_assignment?.assigned_to_name ?? null,
          weaponCleared,
          ammunitionRemoved: ammoRemoved,
          magazinesPresented,
          roundCount,
          opticBatteryStatus: opticBatteryReplaced,
          cleaningCondition,
          result,
          serviceRecommendation,
          followUpDate: followUpDate || null,
          correctiveAction,
          notes,
          checklist,
        }),
      });

      const payload = (await response.json()) as { error?: string };

      if (!response.ok) {
        throw new Error(payload.error ?? "Inspection could not be saved.");
      }

      setSavedMessage("Inspection saved successfully.");
      router.push("/firearms/inspections");
